# Workspace-level env example.
# Per-app envs live in apps/<name>/.env.local

# === apps/api ===
# LLM (chatbot) — self-hosted OpenAI-compatible
LLM_BASE_URL=https://example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=replace-me
LLM_TIMEOUT_MS=20000

# Supabase (server-side only)
SUPABASE_URL=https://tuusgppjfkcijoneojrg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# === apps/miniapp / apps/admin ===
# Public anon key only — KHÔNG dùng service role key trên client
NEXT_PUBLIC_SUPABASE_URL=https://tuusgppjfkcijoneojrg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
