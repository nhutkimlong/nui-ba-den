    "@supabase/supabase-js": "^2.105.4",
    "@types/multer": "^2.1.0",
    "@vercel/node": "^5.8.1",
    "bcryptjs": "^3.0.3",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.6",
